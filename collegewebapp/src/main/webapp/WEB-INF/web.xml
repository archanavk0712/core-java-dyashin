  <url-pattern>/servlet1</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>servlet2</servlet-name>
  <servlet-class>com.dyashin.collegewebapp.common.Servlet2</servlet-class>
  </servlet>
  
  <servlet-mapping>
  <servlet-name>servlet2</servlet-name>
  <url-pattern>/servlet2</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>servlet3</servlet-name>
  <servlet-class>com.dyashin.collegewebapp.common.Servlet3</servlet-class>
  </servlet>
  
  <servlet-mapping>
  <servlet-name>servlet3</servlet-name>
  <url-pattern>/servlet3</url-pattern>
  </servlet-mapping>
